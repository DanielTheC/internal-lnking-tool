# Copy to .env.local and fill in. Never commit real secrets.

# --- Google Search Console API (optional; CSV import works without these) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GSC_OAUTH_REDIRECT_URI=http://localhost:3000/api/gsc/auth/callback
# GSC_ENCRYPTION_SECRET=
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Redis (optional: crawl queue + incremental cache + GSC token storage) ---
# REDIS_URL=redis://127.0.0.1:6379

# --- Server-side crawl archive (full AnalyseResponseBody per run, max 40) ---
# CRAWL_SERVER_SAVE_ENABLED=1
